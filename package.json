{
  "name": "vpc-music",
  "version": "0.1.0",
  "description": "VPC Music — Song management and performance tool with ChordPro support",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build": "node scripts/build-router.mjs",

    "dev:api": "pnpm --filter @vpc-music/api dev",
    "dev:web": "pnpm --filter @vpc-music/web dev",
    "build:api": "pnpm --filter @vpc-music/api build",
    "build:web": "pnpm --filter @vpc-music/web build",

    "test": "pnpm --filter @vpc-music/web test",
    "test:watch": "pnpm --filter @vpc-music/web test:watch",
    "typecheck": "pnpm --filter @vpc-music/web typecheck",
    "lint": "pnpm --filter @vpc-music/web lint",

    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-router.ps1",
    "db:push": "node scripts/db-push.mjs",
    "db:studio": "pnpm --filter @vpc-music/api db:studio",
    "db:generate": "pnpm --filter @vpc-music/api db:generate",
    "db:migrate": "pnpm --filter @vpc-music/api db:migrate",
    "db:seed": "pnpm --filter @vpc-music/api db:seed",

    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:stg": "docker compose -f compose.yml -f compose.stg.yml up -d --build",

    "preflight": "node scripts/preflight.mjs",
    "sync:shared": "powershell -ExecutionPolicy Bypass -File scripts/sync-shared.ps1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

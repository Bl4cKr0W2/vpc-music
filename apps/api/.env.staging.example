# ── VPC Music API — Staging Environment ───────────
# Copy this file to .env.staging and fill in real values.
# The deploy script uploads it to the Droplet automatically.

# ── Database ──────────────────────────────────────
# On a Droplet deploy the compose stack runs its own Postgres.
# This URL matches the postgres service in compose.yml.
DATABASE_URL=postgresql://vpc_music:CHANGE_ME@postgres:5432/vpc_music_stg

# ── API ───────────────────────────────────────────
PORT=3000
NODE_ENV=staging
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://stg-app.vpcmusic.com
FRONTEND_URL=https://stg-app.vpcmusic.com

# ── PDF Parsing ──────────────────────────────────
# PDF_CO_API_KEY=

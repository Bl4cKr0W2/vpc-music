# ── VPC Music API — Production Environment ────────
# Copy this file to .env.production and fill in real values.
# The deploy script uploads it to the Droplet automatically.

# ── Database ──────────────────────────────────────
# On a Droplet deploy the compose stack runs its own Postgres.
# This URL matches the postgres service in compose.yml.
DATABASE_URL=postgresql://vpc_music:CHANGE_ME@postgres:5432/vpc-music-prd

# ── API ───────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://app.vpcmusic.life
FRONTEND_URL=https://app.vpcmusic.life

# ── PDF Parsing ──────────────────────────────────
# PDF_CO_API_KEY=

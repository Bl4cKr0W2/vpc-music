# ── VPC Music API — Production Environment ────────
# Copy this file to .env.production and fill in real values.

# ── Database ──────────────────────────────────────
DB_HOST=YOUR_DB_HOST
DB_PORT=5432
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=vpc-music-prd
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/vpc-music-prd

# ── API ───────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://app.vpcmusic.life
FRONTEND_URL=https://app.vpcmusic.life

# ── PDF Parsing ──────────────────────────────────
# PDF_CO_API_KEY=

# ── Mailgun (API) ────────────────────────────────
MAILGUN_DOMAIN=YOUR_MAILGUN_DOMAIN
MAILGUN_API_KEY=YOUR_MAILGUN_PRIVATE_API_KEY
MAILGUN_API_BASE_URL=https://api.mailgun.net
EMAIL_FROM=VPC Music <noreply@YOUR_MAILGUN_DOMAIN>

# ── OAuth2 — Google ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://app.vpcmusic.life/api/auth/google/callback

# ── VPC Music Web — Environment Variables ─────────
# Copy to .env.local and fill in values.
# Vite requires VITE_ prefix for client-side env vars.

VITE_API_URL=
VITE_VAPID_PUBLIC_KEY=
VITE_LOG_VERBOSE=false

# ── Sandbox Mode ──────────────────────────────────
# Set to "true" to show quick-login buttons with pre-seeded
# demo accounts on the login page (admin, musician, observer).
VITE_SANDBOX=false
